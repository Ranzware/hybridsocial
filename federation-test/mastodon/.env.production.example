# Mastodon production env. Sensitive values (SECRET_KEY_BASE, OTP_SECRET,
# VAPID_PRIVATE_KEY, VAPID_PUBLIC_KEY) are auto-generated by
# scripts/generate-mastodon-secrets.sh into the file at
# `federation-test/mastodon/.env.production` (drop the `.example`).

LOCAL_DOMAIN=mastodon.arab.place
WEB_DOMAIN=mastodon.arab.place
SINGLE_USER_MODE=false

# Postgres
DB_HOST=mastodon_db
DB_USER=mastodon
DB_PASS=changeme_set_to_MASTODON_DB_PASSWORD_in_outer_env
DB_NAME=mastodon_production
DB_PORT=5432

# Redis
REDIS_HOST=mastodon_redis
REDIS_PORT=6379

# Mail (configure if you want signup confirmations to actually send;
# for the testbed we create the admin via tootctl which skips mail)
SMTP_SERVER=
SMTP_PORT=587
SMTP_LOGIN=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=admin@mastodon.arab.place

# File storage — local disk inside the container, persisted via the
# mastodon_public_system volume.
PAPERCLIP_ROOT_PATH=/mastodon/public/system

# These get filled in by generate-mastodon-secrets.sh
SECRET_KEY_BASE=
OTP_SECRET=
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=

# Encryption keys (Mastodon 4.3+ uses these for ActiveRecord encryption)
ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=

RAILS_ENV=production
NODE_ENV=production
