# HybridSocial Production Environment
# Copy this to .env and fill in your values:
#   cp .env.production.example .env

# ---- Required ----

# Your domain (e.g. social.example.com)
DOMAIN=social.example.com

# Database password (use a strong random string)
DB_PASSWORD=changeme_use_a_strong_password

# Phoenix secret key base (run: sh docker/generate-secrets.sh .env)
SECRET_KEY_BASE=

# ---- Optional ----

# Log level (info, debug, warning, error) — use debug for troubleshooting
LOG_LEVEL=info

# Database
DB_USER=hybridsocial
DB_NAME=hybridsocial_prod
POOL_SIZE=10

# Valkey (Redis-compatible) password
VALKEY_PASSWORD=

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=noreply@social.example.com

# Media domain — separate origin for user-uploaded content (security)
# e.g. media.social.example.com — leave empty to serve from main domain
MEDIA_HOST=
MEDIA_DOMAIN=

# S3-compatible storage (leave empty for local uploads)
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=

# Instance actor keys for federation signing
# Auto-generated on first startup by the init-keys container.
# Only set these manually if migrating from another server.
INSTANCE_PUBLIC_KEY=
INSTANCE_PRIVATE_KEY=

# At-rest field-encryption key — encrypts actor private keys, 2FA secrets,
# and emails in the database. Generate with: openssl rand -base64 32
# Losing this key makes all encrypted fields unrecoverable. Back it up!
# Required: the app fails closed if this is missing in production.
DATA_ENCRYPTION_KEY=

# ---- Security stack ----

# Trusted reverse-proxy CIDRs (comma-separated). The backend only honors
# X-Forwarded-For from IPs in these ranges — prevents client-side IP
# spoofing that would bypass IP bans. Default: 127.0.0.0/8 (same-host proxy).
# For a separate proxy host, set to its IP range, e.g. TRUSTED_PROXIES=10.0.0.0/8
TRUSTED_PROXIES=127.0.0.0/8

# CrowdSec → Caddy bouncer shared secret. Auto-generated by
# generate-secrets.sh; rotate with `cscli bouncers add caddy --key <new>`
# inside the crowdsec container, then update this and restart caddy.
CROWDSEC_BOUNCER_CADDY_KEY=

# Email address that receives the 10-minute batched ban digests from
# CrowdSec. SMTP creds reuse the SMTP_* vars above.
CROWDSEC_NOTIFY_EMAIL_TO=admin@social.example.com
